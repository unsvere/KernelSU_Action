CONFIG_ENV=config.env
KERNEL_SOURCE=https://github.com/MiCode/Xiaomi_Kernel_OpenSource.git
KERNEL_SOURCE_BRANCH=light-u-oss
KERNEL_CONFIG=light_defconfig
KERNEL_IMAGE_NAME=Image.gz
ARCH=arm64
USE_CUSTOM_CLANG=true
CUSTOM_CLANG_SOURCE=https://github.com/kdrag0n/proton-clang.git
ENABLE_KERNELSU=true
APPLY_KSU_PATCH=true
CUSTOM_CLANG_BRANCH=master
CLANG_BRANCH=master
ENABLE_GCC_ARM64=false
ENABLE_GCC_ARM32=false
